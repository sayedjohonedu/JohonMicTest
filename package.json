{
  "name": "juno_voice_app",
  "version": "1.1.4",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "postinstall": "electron-rebuild",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.juno.globalvoice",
    "productName": "Juno Global Voice",
    "asar": true,
    "files": [
      "**/*",
      "!**/.DS_Store",
      "!**/node_modules/.cache/**/*",
      "!**/*.md",
      "!**/JUNO_GLOBAL_VOICE_PRD.md",
      "!.chrome-bridge-data/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Juno needs microphone access for speech-to-text."
      }
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "sayedjohon",
      "repo": "juno-voice-releases"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "puppeteer-core": "^24.40.0",
    "robotjs": "^0.7.0",
    "sharp": "^0.34.5",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  }
}
