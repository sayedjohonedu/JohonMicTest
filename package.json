{
  "name": "mictab",
  "version": "1.3.11",
  "description": "MicTab - Voice Dictation App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.mictab.app",
    "productName": "MicTab",
    "icon": "assets/logo/mictablogomain.png",
    "asar": true,
    "files": [
      "**/*",
      "!**/.DS_Store",
      "!**/node_modules/.cache/**/*",
      "!**/*.md",
      "!**/JUNO_GLOBAL_VOICE_PRD.md",
      "!.chrome-bridge-data/**/*",
      "!test_ui.js",
      "!commit_details*.txt",
      "!public-repo-tmp/**/*",
      "!ai_dictation_upgrade.md",
      "!juno_architecture_flow.svg",
      "!macos_focus_fix_summary.md",
      "!**/node_modules/sherpa-onnx-node/**/*",
      "!**/node_modules/sherpa-onnx-darwin*/**/*",
      "!**/node_modules/sherpa-onnx-linux*/**/*",
      "!**/node_modules/sherpa-onnx-win*/**/*",
      "!**/node_modules/node-llama-cpp/**/*",
      "!**/node_modules/@node-llama-cpp/**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!.agent/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "MicTab needs microphone access for speech-to-text."
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "sayedaljohon",
      "repo": "mictab-releases",
      "releaseType": "draft"
    },
    "releaseInfo": {
      "releaseNotesFile": "build/release-notes.md"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hurdlegroup/robotjs": "^0.12.3",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "google-translate-api-x": "^10.7.2",
    "msedge-tts": "^2.0.5",
    "node-addon-api": "^8.7.0",
    "puppeteer-core": "^24.40.0",
    "tesseract.js": "^7.0.0",
    "uiohook-napi": "^1.5.5",
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.18.1",
    "sherpa-onnx-node": "^1.12.39"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  }
}
